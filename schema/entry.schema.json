{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.portolan-sdi.org/registry/schema/entry.schema.json",
  "title": "Portolan Registry Catalog Entry",
  "description": "Schema for registering STAC catalogs. Only the URL is required; all other fields are auto-extracted from the catalog.",
  "type": "object",
  "required": ["url"],
  "additionalProperties": false,
  "properties": {
    "url": {
      "type": "string",
      "format": "uri",
      "pattern": "catalog\\.json$",
      "description": "The URL of the STAC catalog root. This is the ONLY field submitters provide."
    },
    "title": {
      "type": ["string", "null"],
      "description": "Auto-extracted from catalog.title"
    },
    "description": {
      "type": ["string", "null"],
      "description": "Auto-extracted from catalog.description"
    },
    "bbox": {
      "type": ["array", "null"],
      "minItems": 4,
      "maxItems": 4,
      "items": { "type": "number" },
      "description": "Auto-extracted bounding box [west, south, east, north] from collections"
    },
    "license": {
      "type": ["string", "null"],
      "description": "Auto-extracted SPDX license from collections"
    },
    "providers": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "roles": { "type": "array", "items": { "type": "string" } },
          "url": { "type": "string" }
        }
      },
      "description": "Auto-extracted from catalog/collection providers"
    },
    "keywords": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "Auto-extracted keywords from catalog"
    },
    "stac_version": {
      "type": ["string", "null"],
      "description": "Auto-extracted STAC version"
    },
    "collection_count": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Auto-extracted count of collections"
    },
    "feature_count": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Auto-extracted total features across collections"
    },
    "item_count": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Auto-extracted count of items across collections"
    },
    "asset_count": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Auto-extracted count of assets across collections"
    },
    "total_size_bytes": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Auto-extracted sum of file:size across assets"
    },
    "temporal_extent": {
      "type": ["array", "null"],
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": ["string", "null"] },
      "description": "Auto-extracted [start, end] from extent.temporal.interval"
    },
    "api_type": {
      "type": ["string", "null"],
      "enum": ["static", "api", null],
      "description": "Auto-detected: 'api' if /search endpoint exists, else 'static'"
    },
    "last_crawled": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When the catalog was last crawled for metadata"
    },
    "status": {
      "type": ["string", "null"],
      "enum": ["valid", "stale", "removed", null],
      "description": "Current validity state from periodic re-validation"
    },
    "last_validated": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When catalog was last validated for reachability"
    },
    "stale_since": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When catalog first became stale (null if valid)"
    },
    "validation": {
      "type": ["object", "null"],
      "properties": {
        "stac_valid": { "type": ["boolean", "null"] },
        "has_versions_json": { "type": ["boolean", "null"] },
        "has_portolan_dir": { "type": ["boolean", "null"] },
        "has_llms_txt": { "type": ["boolean", "null"] }
      },
      "description": "Auto-populated validation results"
    }
  }
}
